# Example environment variables for FlickerX backend
# Copy this file to `.env` and fill values before running the server.

# Secret used to sign/verify JWTs
JWT_SECRET=your_jwt_secret_here

# OpenRouter API key for chat model
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cloudinary config (if using CLOUDINARY_URL or individual vars)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Frontend origin allowed by CORS
FRONTEND_ORIGIN=http://localhost:5173

# Server port (optional)
PORT=5000
# Environment variables for the backend application
# Replace the placeholder values with your actual configuration
# This file contains environment variables for the backend server, including API keys and configuration settings.
# OpenRouter API key for accessing the OpenRouter service
OPENROUTER_API_KEY=your_openrouter_api_key
# Port on which the backend server will run
PORT=5000
# Cloudinary credentials
CLOUD_NAME=your_cloud_name
API_KEY=your_api_key
API_SECRET=your_api_secret
