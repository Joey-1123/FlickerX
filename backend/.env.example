# Environment variables for the backend application
# Replace the placeholder values with your actual configuration
# This file contains environment variables for the backend server, including API keys and configuration settings.
# OpenRouter API key for accessing the OpenRouter service
OPENROUTER_API_KEY=your_openrouter_api_key
# Port on which the backend server will run
PORT=5000
# Cloudinary credentials
CLOUD_NAME=your_cloud_name
API_KEY=your_api_key
API_SECRET=your_api_secret
