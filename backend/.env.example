# Example environment variables for FlickerX backend
# Copy this file to `.env` and fill values before running the server.

# Secret used to sign and verify JWT tokens
JWT_SECRET=your_jwt_secret_here

# Number of bcrypt salt rounds for password hashing
BCRYPT_SALT_ROUNDS=12

# OpenRouter API key for chat model
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cloudinary credentials (use CLOUDINARY_URL or individual fields below)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend origin allowed by CORS
FRONTEND_ORIGIN=http://localhost:5173

# Server port (optional)
PORT=5000
